/* pages/stats/stats.wxss */
.filter-tab {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(143, 175, 159, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #8C8C8C;
  padding: 16rpx 0;
  border-radius: 32rpx;
  transition: all 0.25s ease;
  font-weight: 500;
}

.tab-item.active {
  background-color: #8FAF9F;
  color: #FFFFFF;
}

/* 自定义日期选择区 */
.custom-date-box {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.custom-date-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.date-picker-btn {
  background-color: #FAF8F5;
  border: 2rpx solid #EAE5E0;
  border-radius: 20rpx;
  padding: 12rpx 30rpx;
  font-size: 26rpx;
  color: #4A4A4A;
  font-weight: 500;
}

.date-sep {
  font-size: 24rpx;
  color: #8C8C8C;
}

/* 数据汇总卡片组 */
.summary-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.sum-card {
  flex: 1;
  padding: 24rpx 16rpx;
  margin-bottom: 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  border-radius: 24rpx;
}

.sum-title {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-bottom: 8rpx;
}

.sum-val {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A4A4A;
  margin-bottom: 4rpx;
}

.sum-val.text-green {
  color: #8FAF9F;
}

.sum-unit {
  font-size: 20rpx;
  font-weight: normal;
  color: #8C8C8C;
  margin-left: 2rpx;
}

.sum-desc {
  font-size: 18rpx;
  color: #BCBCBC;
}

/* 频率趋势图容器 */
.trend-chart-box {
  width: 100%;
  height: 380rpx;
  margin-top: 10rpx;
}

.chart-scroll {
  width: 100%;
  height: 100%;
  white-space: nowrap;
}

.chart-content {
  display: inline-flex;
  align-items: flex-end;
  height: 100%;
  padding: 0 10rpx;
}

.chart-bar-wrapper {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 82rpx;
  height: 100%;
  margin-right: 12rpx;
}

.chart-bar-top-num {
  font-size: 20rpx;
  font-weight: 600;
  color: #8FAF9F;
  margin-bottom: 10rpx;
}

.text-transparent {
  color: transparent;
}

.chart-bar-outer {
  width: 24rpx;
  height: 250rpx;
  background-color: #FAF8F5;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.chart-bar-inner {
  width: 100%;
  background: linear-gradient(to top, #8FAF9F, #A7C2B2);
  border-radius: 12rpx;
  height: 0;
  transition: height 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.chart-bar-label {
  font-size: 20rpx;
  color: #8C8C8C;
  margin-top: 12rpx;
}

/* 布里斯托分布列表 */
.dist-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 10rpx;
}

.dist-item {
  display: flex;
  flex-direction: column;
}

.dist-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.dist-type-info {
  display: flex;
  align-items: center;
}

.dist-emoji {
  font-size: 34rpx;
  margin-right: 12rpx;
}

.dist-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #4A4A4A;
}

.dist-count-info {
  font-size: 22rpx;
}

.dist-count {
  color: #8C8C8C;
  margin-right: 12rpx;
}

.dist-pct {
  font-weight: 600;
  color: #4A4A4A;
}

.progress-outer {
  width: 100%;
  height: 16rpx;
  background-color: #FAF8F5;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  border-radius: 8rpx;
  width: 0;
  transition: width 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.empty-chart {
  padding: 100rpx 0;
  text-align: center;
  color: #8C8C8C;
  font-size: 26rpx;
}

.empty-chart-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}