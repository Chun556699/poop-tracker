/* pages/stats/stats.wxss */
.filter-tab {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(143, 175, 159, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #8C8C8C;
  padding: 16rpx 0;
  border-radius: 32rpx;
  transition: all 0.25s ease;
  font-weight: 500;
}

.tab-item.active {
  background-color: #8FAF9F;
  color: #FFFFFF;
}

/* 自定义日期选择区 */
.custom-date-box {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.custom-date-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.date-picker-btn {
  background-color: #FAF8F5;
  border: 2rpx solid #EAE5E0;
  border-radius: 20rpx;
  padding: 12rpx 30rpx;
  font-size: 26rpx;
  color: #4A4A4A;
  font-weight: 500;
}

.date-sep {
  font-size: 24rpx;
  color: #8C8C8C;
}

/* 数据汇总卡片组 */
.summary-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.sum-card {
  flex: 1;
  padding: 24rpx 16rpx;
  margin-bottom: 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  border-radius: 24rpx;
}

.sum-title {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-bottom: 8rpx;
}

.sum-val {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A4A4A;
  margin-bottom: 4rpx;
}

.sum-val.text-green {
  color: #8FAF9F;
}

.sum-unit {
  font-size: 20rpx;
  font-weight: normal;
  color: #8C8C8C;
  margin-left: 2rpx;
}

.sum-desc {
  font-size: 18rpx;
  color: #BCBCBC;
}

/* 频率趋势图容器 */
.trend-chart-box {
  width: 100%;
  height: 380rpx;
  margin-top: 10rpx;
}

.chart-scroll {
  width: 100%;
  height: 100%;
  white-space: nowrap;
}

.chart-content {
  display: inline-flex;
  align-items: flex-end;
  height: 100%;
  padding: 0 10rpx;
}

.chart-bar-wrapper {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 82rpx;
  height: 100%;
  margin-right: 12rpx;
}

.chart-bar-top-num {
  font-size: 20rpx;
  font-weight: 600;
  color: #8FAF9F;
  margin-bottom: 10rpx;
}

.text-transparent {
  color: transparent;
}

.chart-bar-outer {
  width: 24rpx;
  height: 250rpx;
  background-color: #FAF8F5;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.chart-bar-inner {
  width: 100%;
  background: linear-gradient(to top, #8FAF9F, #A7C2B2);
  border-radius: 12rpx;
  height: 0;
  transition: height 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.chart-bar-label {
  font-size: 20rpx;
  color: #8C8C8C;
  margin-top: 12rpx;
}

/* 布里斯托分布列表 */
.dist-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 10rpx;
}

.dist-item {
  display: flex;
  flex-direction: column;
}

.dist-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.dist-type-info {
  display: flex;
  align-items: center;
}

.dist-emoji {
  font-size: 34rpx;
  margin-right: 12rpx;
}

.dist-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #4A4A4A;
}

.dist-count-info {
  font-size: 22rpx;
}

.dist-count {
  color: #8C8C8C;
  margin-right: 12rpx;
}

.dist-pct {
  font-weight: 600;
  color: #4A4A4A;
}

.progress-outer {
  width: 100%;
  height: 16rpx;
  background-color: #FAF8F5;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  border-radius: 8rpx;
  width: 0;
  transition: width 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.empty-chart {
  padding: 100rpx 0;
  text-align: center;
  color: #8C8C8C;
  font-size: 26rpx;
}

.empty-chart-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

/* ==========================================================================
   排便记录日历可视化样式
   ========================================================================== */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.calendar-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #4A4A4A;
}

.calendar-month-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.month-btn {
  font-size: 18rpx;
  color: #8FAF9F;
  background-color: rgba(143, 175, 159, 0.1);
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  font-weight: bold;
  transition: opacity 0.15s ease;
}

.month-btn:active {
  opacity: 0.6;
}

.month-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #4A4A4A;
  min-width: 140rpx;
  text-align: center;
}

.calendar-weeks {
  display: flex;
  margin-bottom: 16rpx;
  padding-bottom: 8rpx;
  border-bottom: 2rpx solid #FAF8F5;
}

.week-label {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #BCBCBC;
  font-weight: 600;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  row-gap: 12rpx;
}

.calendar-day {
  width: 14.28%; /* 7列完美平分 */
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 18rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.calendar-day.placeholder {
  pointer-events: none;
  background-color: transparent !important;
}

.calendar-day.today {
  border: 2rpx dashed #8FAF9F;
  background-color: rgba(143, 175, 159, 0.05);
}

.calendar-day.has-records {
  background-color: rgba(217, 195, 176, 0.12); /* 温馨舒缓的奶茶棕色底 */
}

.day-num {
  font-size: 24rpx;
  font-weight: 600;
  color: #555555;
}

.calendar-day.placeholder .day-num {
  color: transparent;
}

.day-emoji {
  font-size: 26rpx;
  margin-top: 4rpx;
  line-height: 1;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #8FAF9F;
  border-radius: 50%;
  position: absolute;
  bottom: 8rpx;
}

.calendar-tips {
  font-size: 20rpx;
  color: #BCBCBC;
  margin-top: 24rpx;
  text-align: center;
  background-color: #FAF8F5;
  padding: 12rpx;
  border-radius: 12rpx;
}