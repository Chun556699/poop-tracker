/* pages/record/record.wxss */
.slider-box {
  padding: 10rpx 0;
}

.duration-display {
  text-align: center;
  font-size: 28rpx;
  color: #4A4A4A;
  margin-bottom: 20rpx;
}

.duration-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #8FAF9F;
  margin: 0 6rpx;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #8C8C8C;
  padding: 0 10rpx;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-picker {
  flex: 1;
}

.picker-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
}

.picker-label {
  font-size: 24rpx;
  color: #8C8C8C;
  margin-bottom: 8rpx;
}

.picker-value {
  font-size: 30rpx;
  font-weight: 500;
  color: #4A4A4A;
}

.picker-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #EAE5E0;
}

.notes-textarea {
  width: 100%;
  height: 150rpx;
  background-color: #FAF8F5;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #4A4A4A;
  line-height: 1.5;
  box-sizing: border-box;
}

.notes-placeholder {
  color: #8C8C8C;
  font-size: 26rpx;
}

.photo-upload-box {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 10rpx;
}

.photo-placeholder {
  width: 100%;
  height: 240rpx;
  border: 2rpx dashed #D9C3B0;
  border-radius: 24rpx;
  background-color: #FAF8F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.photo-placeholder:active {
  background-color: #F0EDE8;
}

.photo-icon {
  font-size: 54rpx;
  color: #8FAF9F;
  margin-bottom: 8rpx;
}

.photo-text {
  font-size: 26rpx;
  color: #4A4A4A;
  font-weight: 500;
}

.photo-tip {
  font-size: 20rpx;
  color: #8C8C8C;
  margin-top: 6rpx;
}

.photo-preview-wrapper {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(143, 175, 159, 0.15);
}

.photo-preview {
  width: 100%;
  height: 100%;
}

.delete-photo-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.45);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.save-btn {
  margin: 40rpx 0 60rpx 0;
  height: 94rpx;
  box-shadow: 0 8rpx 30rpx rgba(143, 175, 159, 0.3);
}

.btn-delete {
  margin-top: 0;
  background-color: #FFFFFF;
  color: #E8A08A;
  border: 2rpx solid #E8A08A;
  box-shadow: none;
}

.btn-delete-hover {
  background-color: #FFF0EC;
  opacity: 0.9;
}