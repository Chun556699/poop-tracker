.filter-tab {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(143, 175, 159, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #8C8C8C;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background-color: #8FAF9F;
  color: #FFFFFF;
  font-weight: 600;
}

.my-rank-card {
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, rgba(143, 175, 159, 0.08), rgba(217, 195, 176, 0.06));
  border: 2rpx solid rgba(143, 175, 159, 0.15);
  margin-bottom: 24rpx;
}

.my-rank-label {
  font-size: 24rpx;
  color: #8FAF9F;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.my-rank-value {
  font-size: 34rpx;
  font-weight: bold;
  color: #4A4A4A;
}

.my-rank-tip {
  font-size: 22rpx;
  color: #D9C3B0;
  margin-top: 6rpx;
}

.rank-list {
  display: flex;
  flex-direction: column;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  margin-bottom: 16rpx;
}

.card-hover {
  opacity: 0.9;
  background-color: #FAF8F5;
}

.rank-num-box {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.rank-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #8C8C8C;
}

.rank-medal {
  font-size: 40rpx;
}

.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(143, 175, 159, 0.12);
  margin-right: 18rpx;
  background-color: #FAF8F5;
  flex-shrink: 0;
}

.rank-info {
  flex: 1;
}

.rank-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A4A4A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 240rpx;
}

.rank-count {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-top: 4rpx;
}

.rank-badge {
  flex-shrink: 0;
  background-color: rgba(143, 175, 159, 0.1);
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #8FAF9F;
  font-weight: 500;
}

.empty-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8C8C8C;
  font-weight: 500;
}

.empty-tip {
  font-size: 24rpx;
  color: #BCBCBC;
  margin-top: 10rpx;
}

.loading-box {
  display: flex;
  justify-content: center;
  padding: 60rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #8C8C8C;
}
