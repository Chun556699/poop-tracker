/* pages/mine/mine.wxss */
.profile-card {
  padding: 40rpx 30rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(143, 175, 159, 0.15);
}

.profile-info {
  margin-left: 24rpx;
}

.nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #4A4A4A;
}

.sync-badge {
  display: inline-flex;
  align-items: center;
  background-color: rgba(143, 175, 159, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 10rpx;
}

.sync-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #8FAF9F;
  border-radius: 50%;
  margin-right: 8rpx;
  animation: breathe 2s infinite ease-in-out;
}

@keyframes breathe {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

.sync-text {
  font-size: 20rpx;
  font-weight: 500;
  color: #8FAF9F;
}

.cloud-intro {
  font-size: 24rpx;
  color: #8C8C8C;
  line-height: 1.5;
  background-color: #FAF8F5;
  padding: 22rpx;
  border-radius: 16rpx;
}

/* 科普指南入口 */
.science-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
}

.science-entry-left {
  display: flex;
  align-items: center;
}

.science-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.science-info {
  display: flex;
  flex-direction: column;
}

.science-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A4A4A;
}

.science-desc {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-top: 4rpx;
}

.science-arrow {
  font-size: 24rpx;
  color: #8FAF9F;
  background-color: rgba(143, 175, 159, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* 选项列表 */
.menu-list {
  padding: 10rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 30rpx;
  border-bottom: 2rpx solid #FAF8F5;
  transition: background-color 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background-color: #FAF8F5;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 34rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #4A4A4A;
}

.menu-arrow {
  font-size: 20rpx;
  color: #BCBCBC;
}

.text-red {
  color: #D07A70 !important;
}

/* 重置微信 button 默认不可控边框 */
.feedback-btn {
  background-color: transparent !important;
  line-height: normal !important;
  width: 100% !important;
  text-align: left !important;
  border-radius: 0 !important;
  margin: 0 !important;
  padding: 30rpx 30rpx !important;
  font-weight: normal !important;
}

.feedback-btn::after {
  border: none !important;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.25s ease;
}

.modal-box {
  width: 86%;
  background-color: #FFFFFF;
  border-radius: 36rpx;
  padding: 36rpx;
  box-sizing: border-box;
  animation: popIn 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  display: flex;
  flex-direction: column;
}

@keyframes popIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #FAF8F5;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #4A4A4A;
}

.modal-close {
  font-size: 40rpx;
  color: #BCBCBC;
  padding: 0 10rpx;
}

/* 滚动容器 */
.modal-scroll {
  max-height: 70vh;
}

.science-item-card {
  background-color: #FAF8F5;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #8FAF9F;
}

.sci-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sci-type-badge {
  font-size: 20rpx;
  font-weight: bold;
  color: #FFFFFF;
  background-color: #8FAF9F;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.sci-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #4A4A4A;
}

.sci-status {
  font-size: 22rpx;
  color: #8FAF9F;
  font-weight: 500;
  margin-top: 8rpx;
}

.sci-desc {
  font-size: 22rpx;
  color: #8C8C8C;
  line-height: 1.5;
  margin-top: 10rpx;
}

/* 关于页面内容 */
.about-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 10rpx;
}

.about-logo-img {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
}

.about-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #4A4A4A;
}

.about-desc {
  font-size: 24rpx;
  color: #6A6A6A;
  line-height: 1.6;
  text-align: center;
  margin-top: 24rpx;
  background-color: #FAF8F5;
  padding: 26rpx;
  border-radius: 24rpx;
}

.about-footer {
  font-size: 20rpx;
  color: #BCBCBC;
  margin-top: 40rpx;
}

.profile-actions {
  margin-top: 20rpx;
}

.action-btn {
  display: inline-block;
  font-size: 24rpx;
  color: #8FAF9F;
  background-color: rgba(143, 175, 159, 0.1);
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.action-logout {
  color: #E8A08A;
  background-color: rgba(232, 160, 138, 0.1);
}

.action-btn-hover {
  opacity: 0.7;
}

.login-modal {
  max-height: 80vh;
}

.login-form {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.preview-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(143, 175, 159, 0.15);
}

.avatar-btns {
  display: flex;
  gap: 16rpx;
  width: 100%;
  margin-bottom: 24rpx;
}

.wx-avatar-btn,
.custom-avatar-btn {
  flex: 1;
  font-size: 24rpx;
  padding: 18rpx 0;
  border-radius: 32rpx;
  line-height: 1;
  border: none;
  text-align: center;
  background: none;
}

.wx-avatar-btn::after,
.custom-avatar-btn::after {
  border: none;
}

.wx-avatar-btn {
  color: #FFFFFF;
  background-color: #8FAF9F;
  box-shadow: 0 4rpx 16rpx rgba(143, 175, 159, 0.25);
}

.custom-avatar-btn {
  color: #8FAF9F;
  background-color: #FFFFFF;
  border: 2rpx solid #8FAF9F;
}

.avatar-btn-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.avatar-btn-icon {
  font-size: 28rpx;
  line-height: 1;
}

.avatar-btn-label {
  font-size: 24rpx;
  font-weight: 500;
}

.nickname-section {
  width: 100%;
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 24rpx;
  color: #8C8C8C;
  margin-bottom: 10rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  background-color: #FAF8F5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #4A4A4A;
  box-sizing: border-box;
}

.login-confirm-btn {
  width: 100%;
  height: 84rpx;
  background-color: #8FAF9F;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}