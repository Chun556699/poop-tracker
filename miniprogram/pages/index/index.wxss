/* pages/index/index.wxss */
.greeting-box {
  margin: 10rpx 0 30rpx 0;
}

.greeting-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A4A4A;
  margin-bottom: 8rpx;
}

.greeting-desc {
  font-size: 26rpx;
  color: #8C8C8C;
  line-height: 1.5;
}

/* 统计网格 */
.stats-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stat-card {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 28rpx;
  padding: 34rpx 30rpx;
  box-shadow: 0 4rpx 24rpx rgba(143, 175, 159, 0.04);
  text-align: center;
}

.stat-num {
  font-size: 56rpx;
  font-weight: bold;
  color: #8FAF9F;
  margin-bottom: 6rpx;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: #8C8C8C;
}

/* 一键大记录按钮 */
.record-btn-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 10rpx 0 50rpx 0;
}

.record-btn {
  width: 100%;
  height: 154rpx;
  background: linear-gradient(135deg, #8FAF9F, #A7C2B2);
  border-radius: 36rpx;
  box-shadow: 0 12rpx 36rpx rgba(143, 175, 159, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.record-btn-hover {
  transform: translateY(4rpx);
  box-shadow: 0 6rpx 16rpx rgba(143, 175, 159, 0.25);
  opacity: 0.95;
}

.record-btn-inner {
  display: flex;
  align-items: center;
}

.record-emoji {
  font-size: 56rpx;
  margin-right: 20rpx;
  animation: bounce 2s infinite ease-in-out;
}

.record-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

/* 计时按钮 */
.timer-btn-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 0 50rpx 0;
}

.timer-btn {
  width: 100%;
  height: 120rpx;
  background: linear-gradient(135deg, #D9C3B0, #E8D5C4);
  border-radius: 36rpx;
  box-shadow: 0 8rpx 28rpx rgba(217, 195, 176, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.timer-btn-active {
  background: linear-gradient(135deg, #E8A08A, #F0B8A8);
  box-shadow: 0 8rpx 32rpx rgba(232, 160, 138, 0.4);
  animation: timerPulse 2s infinite ease-in-out;
}

.timer-btn-hover {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 12rpx rgba(217, 195, 176, 0.2);
  opacity: 0.95;
}

.timer-btn-inner {
  display: flex;
  align-items: center;
}

.timer-icon {
  font-size: 48rpx;
  margin-right: 18rpx;
}

.timer-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 3rpx;
  font-variant-numeric: tabular-nums;
}

.timer-hint {
  font-size: 22rpx;
  color: #E8A08A;
  margin-top: 12rpx;
  animation: fadeIn 0.3s ease-in;
}

@keyframes timerPulse {
  0%, 100% {
    box-shadow: 0 8rpx 32rpx rgba(232, 160, 138, 0.4);
  }
  50% {
    box-shadow: 0 8rpx 48rpx rgba(232, 160, 138, 0.6);
  }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 记录列表区域 */
.section {
  display: flex;
  flex-direction: column;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4A4A4A;
}

.record-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.card-hover {
  background-color: #FAF8F5;
  border-color: #EAE5E0;
}

.record-card-main {
  display: flex;
  align-items: center;
}

.record-card-emoji {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.record-card-info {
  flex: 1;
}

.record-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A4A4A;
}

.record-card-time {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-top: 6rpx;
}

.record-card-sub {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid #FAF8F5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-notes {
  font-size: 24rpx;
  color: #6A6A6A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 12rpx;
}

.photo-badge {
  font-size: 20rpx;
  color: #8FAF9F;
  background-color: #FAF8F5;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(143, 175, 159, 0.2);
}

/* 空列表占位 */
.empty-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: float 3s infinite ease-in-out;
}

.empty-text {
  font-size: 28rpx;
  color: #4A4A4A;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 22rpx;
  color: #8C8C8C;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}